# PostgreSQL
DATABASE_URL=postgresql+asyncpg://uja:uja@localhost:5432/uja_iaph

# Embedding service
EMBEDDING_SERVICE_URL=http://localhost:8001

# Embedding model selection (uncomment one block):
# --- MrBERT ---
# EMBEDDING_MODEL_DIR=MrBERT
# POOLING_STRATEGY=mean
# MAX_LENGTH=8192
# EMBEDDING_DIM=768
# --- Qwen3-Embedding-0.6B ---
EMBEDDING_MODEL_DIR=Qwen3-Embedding-0.6B
POOLING_STRATEGY=last_token
MAX_LENGTH=32768
EMBEDDING_DIM=1024

# LLM service (salamandra-7b-instruct via vLLM)
LLM_SERVICE_URL=http://localhost:8000/v1
LLM_MODEL_NAME=BSC-LT/salamandra-7b-instruct
LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=0.7

# RAG settings
RAG_TOP_K=5
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=64
# Chunk table version: v1 (fixed window), v2 (paragraphs + basic header),
# v3 (paragraphs + type-specific metadata header + JSONB), v4 (natural language templates + JSONB)
CHUNKS_TABLE_VERSION=v1

# API
API_V1_PREFIX=/api/v1
PROJECT_NAME=IAPH Heritage RAG
DEBUG=true
