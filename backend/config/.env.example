# PostgreSQL
DATABASE_URL=postgresql+asyncpg://uja:uja@localhost:5432/uja_iaph

# Embedding service
EMBEDDING_SERVICE_URL=http://localhost:8001

# Embedding model selection (uncomment one block):
# --- MrBERT ---
# EMBEDDING_MODEL_DIR=MrBERT
# POOLING_STRATEGY=mean
# MAX_LENGTH=8192
# EMBEDDING_DIM=768
# --- Qwen3-Embedding-0.6B ---
EMBEDDING_MODEL_DIR=Qwen3-Embedding-0.6B
POOLING_STRATEGY=last_token
MAX_LENGTH=32768
EMBEDDING_DIM=1024

# Qwen3 instruction prefix for query embeddings (empty to disable, e.g. for MrBERT)
EMBEDDING_QUERY_INSTRUCTION=Retrieve relevant heritage documents.

# API keys for internal services (empty = no auth)
EMBEDDING_API_KEY=
LLM_API_KEY=

# LLM provider: "gemini" or "vllm"
LLM_PROVIDER=vllm

# vLLM service (salamandra-7b-instruct)
LLM_SERVICE_URL=http://localhost:8000/v1
LLM_MODEL_NAME=BSC-LT/salamandra-7b-instruct
LLM_MAX_TOKENS=512
LLM_ROUTE_NARRATIVE_MAX_TOKENS=2048
LLM_TEMPERATURE=0.3

# Gemini
# GEMINI_API_KEY=
# GEMINI_MODEL_NAME=gemini-3.1-flash-lite-preview

# RAG settings
RAG_SIMILARITY_ONLY=false
RAG_SIMILARITY_THRESHOLD=0.45
RAG_TOP_K=5
RAG_RETRIEVAL_K=20
RAG_SCORE_THRESHOLD=0.50
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=64
# Chunk table version: v1 (fixed window), v2 (paragraphs + basic header),
# v3 (paragraphs + type-specific metadata header + JSONB), v4 (natural language templates + JSONB)
CHUNKS_TABLE_VERSION=v1

# Search settings (separate from RAG)
SEARCH_RETRIEVAL_K=200
SEARCH_SCORE_THRESHOLD=0.55

# API
API_V1_PREFIX=/api/v1
PROJECT_NAME=IAPH Heritage RAG
DEBUG=true

# CORS (comma-separated origins, or * for all)
CORS_ORIGINS=*

# Auth (JWT-based, hardcoded credentials for PoC)
AUTH_USERNAME=admin
AUTH_PASSWORD=admin
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
