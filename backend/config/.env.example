# =============================================================================
# backend/config/.env.example — Backend (FastAPI) configuration
# =============================================================================
#
# Used when running the backend LOCALLY (not in Docker).
# Copy to backend/config/.env and adjust:
#
#   cp backend/config/.env.example backend/config/.env
#
# Service URLs point to localhost with exposed Docker host ports (15432, 18001,
# 18000) because the backend runs outside the Docker network.
#
# For Docker Compose deployment, use the root .env instead — service-to-service
# URLs are built automatically inside docker-compose.yml.
# =============================================================================


# =============================================================================
# DATABASE
# =============================================================================

DATABASE_URL=postgresql+asyncpg://uja:uja@localhost:15432/uja_iaph


# =============================================================================
# EMBEDDING SERVICE (connector)
# =============================================================================
# URL and dimension are all the backend needs — the embedding service itself
# is configured via the root .env / docker-compose.yml.

EMBEDDING_SERVICE_URL=http://localhost:18001
EMBEDDING_DIM=1024

# Instruction prefix prepended to queries before encoding (Qwen3 is
# instruction-aware). Leave empty for MrBERT.
EMBEDDING_QUERY_INSTRUCTION=Retrieve relevant heritage documents.


# =============================================================================
# LLM SERVICE (connector)
# =============================================================================
# LLM_PROVIDER selects the backend: "vllm" (self-hosted) or "gemini" (Google API).
# The vLLM service itself is configured via the root .env / docker-compose.yml.

LLM_PROVIDER=vllm
LLM_SERVICE_URL=http://localhost:18000/v1
LLM_MODEL_NAME=BSC-LT/salamandra-7b-instruct
LLM_API_KEY=
LLM_MAX_TOKENS=512
LLM_ROUTE_NARRATIVE_MAX_TOKENS=2048
LLM_TEMPERATURE=0.3

# Gemini (required when LLM_PROVIDER=gemini)
# GEMINI_API_KEY=
# GEMINI_MODEL_NAME=gemini-3.1-flash-lite-preview


# =============================================================================
# RAG PIPELINE
# =============================================================================

RAG_SIMILARITY_ONLY=false
RAG_SIMILARITY_THRESHOLD=0.45
RAG_TOP_K=5
RAG_RETRIEVAL_K=20
RAG_SCORE_THRESHOLD=0.50
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=64
CHUNKS_TABLE_VERSION=v1


# =============================================================================
# SEARCH
# =============================================================================

SEARCH_RETRIEVAL_K=200
SEARCH_SCORE_THRESHOLD=0.55


# =============================================================================
# RERANKER (connector — served by embedding service at /rerank)
# =============================================================================

RERANKER_ENABLED=false
RERANKER_SERVICE_URL=http://localhost:18001
RERANKER_INSTRUCTION=Given a heritage search query, retrieve relevant heritage documents.
RERANKER_TOP_N=50


# =============================================================================
# GCP (Cloud Run IAM auth from non-GCP servers)
# =============================================================================
# Generate with: gcloud iam service-accounts keys create key.json --iam-account=embedding-invoker@innovasur-uja-alia.iam.gserviceaccount.com
# Then compact: cat key.json | python3 -c "import sys,json; print(json.dumps(json.load(sys.stdin)))"

GCP_SERVICE_ACCOUNT_JSON=


# =============================================================================
# API
# =============================================================================

API_V1_PREFIX=/api/v1
PROJECT_NAME=IAPH Heritage RAG
DEBUG=true
CORS_ORIGINS=*


# =============================================================================
# LOGGING
# =============================================================================

LOG_RETENTION_DAYS=60


# =============================================================================
# AUTH
# =============================================================================

JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin
