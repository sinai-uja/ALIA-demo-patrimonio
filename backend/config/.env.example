# PostgreSQL
DATABASE_URL=postgresql+asyncpg://uja:uja@localhost:15432/uja_iaph

# Embedding service
EMBEDDING_SERVICE_URL=http://localhost:18001

# Embedding model selection (uncomment one block):
# --- MrBERT ---
# EMBEDDING_MODEL_DIR=MrBERT
# POOLING_STRATEGY=mean
# MAX_LENGTH=8192
# EMBEDDING_DIM=768
# --- Qwen3-Embedding-0.6B ---
EMBEDDING_MODEL_DIR=Qwen3-Embedding-0.6B
POOLING_STRATEGY=last_token
MAX_LENGTH=32768
EMBEDDING_DIM=1024

# Qwen3 instruction prefix for query embeddings (empty to disable, e.g. for MrBERT)
EMBEDDING_QUERY_INSTRUCTION=Retrieve relevant heritage documents.

LLM_API_KEY=

# LLM provider: "gemini" or "vllm"
LLM_PROVIDER=vllm

# vLLM service
# For salamandra-7b: LLM_MODEL_NAME=BSC-LT/salamandra-7b-instruct
# For ALIA-40b:      LLM_MODEL_NAME=BSC-LT/ALIA-40b-instruct-2601
LLM_SERVICE_URL=http://localhost:18000/v1
LLM_MODEL_NAME=BSC-LT/salamandra-7b-instruct
LLM_MAX_TOKENS=512
LLM_ROUTE_NARRATIVE_MAX_TOKENS=2048
LLM_TEMPERATURE=0.3

# Gemini
# GEMINI_API_KEY=
# GEMINI_MODEL_NAME=gemini-3.1-flash-lite-preview

# RAG settings
RAG_SIMILARITY_ONLY=false
RAG_SIMILARITY_THRESHOLD=0.45
RAG_TOP_K=5
RAG_RETRIEVAL_K=20
RAG_SCORE_THRESHOLD=0.50
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=64
# Chunk table version: v1 (fixed window), v2 (paragraphs + basic header),
# v3 (paragraphs + type-specific metadata header + JSONB), v4 (natural language templates + JSONB)
CHUNKS_TABLE_VERSION=v1

# Search settings (separate from RAG)
SEARCH_RETRIEVAL_K=200
SEARCH_SCORE_THRESHOLD=0.55

# Reranker (co-located with embedding service at /rerank)
RERANKER_ENABLED=false
RERANKER_SERVICE_URL=http://localhost:18001
RERANKER_INSTRUCTION=Given a heritage search query, retrieve relevant heritage documents.
RERANKER_TOP_N=50
RERANKER_MAX_LENGTH=1024
RERANKER_BATCH_SIZE=1

# GCP (for Cloud Run IAM auth from non-GCP servers, empty = use default credentials)
# Generate with: gcloud iam service-accounts keys create key.json --iam-account=embedding-invoker@innovasur-uja-alia.iam.gserviceaccount.com
# Then compact: cat key.json | python3 -c "import sys,json; print(json.dumps(json.load(sys.stdin)))"
GCP_SERVICE_ACCOUNT_JSON=

# API
API_V1_PREFIX=/api/v1
PROJECT_NAME=IAPH Heritage RAG
DEBUG=true

# CORS (comma-separated origins, or * for all)
CORS_ORIGINS=*

# Auth (JWT-based, DB-backed users — create via: make manage-users ARGS="create-user ...")
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# Server port (default 20000 in Docker, 18080 in local dev)
# PORT=20000
