# =============================================================================
# .env.example — Docker Compose configuration for IAPH RAG Monorepo
# =============================================================================
#
# This file documents ALL environment variables used by docker-compose.yml.
# Copy it to .env and adjust values for your environment:
#
#   cp .env.example .env
#
# Docker Compose loads .env automatically from the project root.
# Service-to-service URLs (DATABASE_URL, EMBEDDING_SERVICE_URL, LLM_SERVICE_URL)
# are built inside docker-compose.yml using Docker network hostnames — you do
# NOT need to set them here.
#
# For local development WITHOUT Docker, use backend/config/.env instead
# (which points to localhost with exposed host ports).
#
# Organisation: variables are grouped by the service that owns them.
# =============================================================================


# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║  POSTGRESQL                                                              ║
# ╚═══════════════════════════════════════════════════════════════════════════╝
# pgvector/pgvector:pg16 container. Creates the database on first run.
# If you change them after the volume is initialised: docker compose down -v

POSTGRES_DB=uja_iaph
POSTGRES_USER=uja
POSTGRES_PASSWORD=uja


# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║  EMBEDDING SERVICE                                                       ║
# ╚═══════════════════════════════════════════════════════════════════════════╝
# Loads a transformer encoder model and serves embeddings (POST /embed)
# and optional cross-encoder reranking (POST /rerank).
#
# ┌──────────────────────┬───────────────────────┬──────────────────────────┐
# │                      │ MrBERT (default)      │ Qwen3-Embedding-0.6B     │
# ├──────────────────────┼───────────────────────┼──────────────────────────┤
# │ EMBEDDING_MODEL_DIR  │ MrBERT                │ Qwen3-Embedding-0.6B     │
# │ POOLING_STRATEGY     │ mean                  │ last_token               │
# │ MAX_LENGTH           │ 8192                  │ 32768                    │
# │ EMBEDDING_DIM        │ 768                   │ 1024                     │
# └──────────────────────┴───────────────────────┴──────────────────────────┘
#
# IMPORTANT: Changing encoder requires re-ingesting all documents.
# Model files must exist at backend/models/<EMBEDDING_MODEL_DIR>/

EMBEDDING_MODEL_DIR=Qwen3-Embedding-0.6B
POOLING_STRATEGY=last_token
MAX_LENGTH=32768
EMBEDDING_DIM=1024

# Instruction prefix for query encoding (Qwen3 is instruction-aware).
# Leave empty for MrBERT.
EMBEDDING_QUERY_INSTRUCTION=Recupera elementos patrimoniales relevantes para la siguiente consulta.

# Reranker (co-located with embedding service at POST /rerank)
# Download model: cd backend && make download-reranker
RERANKER_MAX_LENGTH=1024
RERANKER_BATCH_SIZE=1


# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║  LLM SERVICE                                                             ║
# ╚═══════════════════════════════════════════════════════════════════════════╝
# vLLM container (profile "llm"). Serves OpenAI-compatible chat/completions.
#
# ┌─────────────────────────────────┬──────────────────────────────────────────────────────────────┬──────────┬──────────────┐
# │ Model                           │ LLM_QUANTIZATION_ARGS                                      │ Entorno  │ Min GPU VRAM │
# ├─────────────────────────────────┼──────────────────────────────────────────────────────────────┼──────────┼──────────────┤
# │ BSC-LT/salamandra-7b-instruct  │ --dtype bfloat16                                             │ Local    │ 14 GB        │
# │ agustim/ALIA-40b-GPTQ-INT4     │ --quantization gptq --dtype float16                          │ Cloud    │ 26 GB (A100) │
# └─────────────────────────────────┴──────────────────────────────────────────────────────────────┴──────────┴──────────────┘
#
# Local: salamandra-7b (14GB VRAM, cabe en cualquier GPU)
# Cloud Run: ALIA-40b GPTQ (25GB VRAM, A100 40GB, deploy scripts lo configuran)

# LLM_MODEL_NAME — HuggingFace model ID (used by backend to identify the model)
# LLM_MODEL_DIR  — directory name under backend/models/ (mounted into container)
# LLM_MODEL_PATH — path inside the container (/app/model when mounted locally,
#                   or HuggingFace ID to download from HF Hub)

LLM_MODEL_NAME=BSC-LT/salamandra-7b-instruct
LLM_MODEL_DIR=salamandra-7b-instruct
LLM_MODEL_PATH=/app/model
LLM_QUANTIZATION_ARGS=
LLM_MAX_MODEL_LEN=4096
LLM_API_KEY=


# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║  BACKEND API (FastAPI)                                                   ║
# ╚═══════════════════════════════════════════════════════════════════════════╝

# --- LLM provider selection ---
# "vllm" = self-hosted via LLM service (requires profile "llm")
# "gemini" = Google Gemini API (no GPU needed)
LLM_PROVIDER=gemini

# --- Generation parameters (apply to both providers) ---
LLM_MAX_TOKENS=512
LLM_ROUTE_NARRATIVE_MAX_TOKENS=2048
LLM_TEMPERATURE=0.7

# --- Gemini credentials (required when LLM_PROVIDER=gemini) ---
GEMINI_API_KEY=
GEMINI_MODEL_NAME=gemini-3.1-flash-lite-preview

# --- RAG pipeline ---
RAG_SIMILARITY_ONLY=true
RAG_SIMILARITY_THRESHOLD=0.45
RAG_TOP_K=5
RAG_RETRIEVAL_K=20
RAG_SCORE_THRESHOLD=0.35
RAG_CHUNK_SIZE=1024
RAG_CHUNK_OVERLAP=128
CHUNKS_TABLE_VERSION=v4

# --- Reranker (connector — uses embedding service's /rerank endpoint) ---
RERANKER_ENABLED=false
RERANKER_INSTRUCTION=Given a heritage search query, retrieve relevant heritage documents.
RERANKER_TOP_N=50

# --- Search (separate thresholds from RAG) ---
SEARCH_RETRIEVAL_K=200
SEARCH_SCORE_THRESHOLD=0.55

# --- API settings ---
API_V1_PREFIX=/api/v1
PROJECT_NAME=IAPH Heritage RAG
DEBUG=false
CORS_ORIGINS=*

# --- Logging ---
LOG_RETENTION_DAYS=60

# --- Auth (JWT-based, DB-backed users) ---
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin


# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║  FRONTEND (Next.js)                                                      ║
# ╚═══════════════════════════════════════════════════════════════════════════╝
# NEXT_PUBLIC_API_URL is the backend URL as seen by the user's BROWSER.
# Baked into the JS bundle at build time (not the internal Docker URL).

NEXT_PUBLIC_API_URL=http://localhost:18080/api/v1


# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║  PORTS                                                                   ║
# ╚═══════════════════════════════════════════════════════════════════════════╝
# Host ports exposed by each service. Container-internal ports are fixed.

POSTGRES_PORT=15432
EMBEDDING_PORT=18001
LLM_PORT=18000
API_PORT=18080
FRONTEND_PORT=3000


# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║  QUICK PRESETS                                                           ║
# ╚═══════════════════════════════════════════════════════════════════════════╝
#
# Salamandra-7b LOCAL (14GB VRAM, cualquier GPU, default):
#   LLM_PROVIDER=vllm
#   LLM_MODEL_NAME=BSC-LT/salamandra-7b-instruct
#   LLM_QUANTIZATION_ARGS=--dtype bfloat16
#   LLM_MAX_MODEL_LEN=4096
#
# ALIA-40b CLOUD RUN (GPTQ, A100 40GB — deploy scripts lo configuran automaticamente):
#   LLM_PROVIDER=vllm
#   LLM_MODEL_NAME=agustim/ALIA-40b-GPTQ-INT4
#   LLM_QUANTIZATION_ARGS=--quantization gptq --dtype float16
#   LLM_MAX_MODEL_LEN=8192
#   LLM_TEMPERATURE=0.1
#
# Gemini (Google API, no GPU needed):
#   LLM_PROVIDER=gemini
#   GEMINI_API_KEY=<your-key>
#   GEMINI_MODEL_NAME=gemini-3.1-flash-lite-preview
