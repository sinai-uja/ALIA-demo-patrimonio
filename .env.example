# =============================================================================
# .env.example — Docker Compose configuration for IAPH RAG Monorepo
# =============================================================================
#
# This file documents ALL environment variables used by docker-compose.yml.
# Copy it to .env and adjust values for your environment:
#
#   cp .env.example .env
#
# Docker Compose loads .env automatically from the project root.
# Variables here configure four services: PostgreSQL, Embedding, API, Frontend.
# Service-to-service URLs (DATABASE_URL, EMBEDDING_SERVICE_URL, LLM_SERVICE_URL)
# are built inside docker-compose.yml using Docker network hostnames — you do
# NOT need to set them here.
#
# For local development WITHOUT Docker, use backend/config/.env instead
# (which points to localhost with exposed host ports).
# =============================================================================


# =============================================================================
# POSTGRESQL
# =============================================================================
# Database name, user and password for the pgvector/pgvector:pg16 container.
# These create the database on first run. If you change them after the volume
# is initialised, you must drop the volume: docker compose down -v

POSTGRES_DB=uja_iaph
POSTGRES_USER=uja
POSTGRES_PASSWORD=uja


# =============================================================================
# EMBEDDING SERVICE
# =============================================================================
# The embedding service loads a transformer encoder model from a volume-mounted
# directory and serves embeddings via HTTP. Two models are supported:
#
# ┌──────────────────────┬───────────────────────┬──────────────────────────┐
# │                      │ MrBERT (default)      │ Qwen3-Embedding-0.6B     │
# ├──────────────────────┼───────────────────────┼──────────────────────────┤
# │ EMBEDDING_MODEL_DIR  │ MrBERT                │ Qwen3-Embedding-0.6B     │
# │ POOLING_STRATEGY     │ mean                  │ last_token               │
# │ MAX_LENGTH           │ 8192                  │ 32768                    │
# │ EMBEDDING_DIM        │ 768                   │ 1024                     │
# │ Parameters           │ 308M                  │ 600M                     │
# │ Languages            │ 35 (incl. ES)         │ 100+                     │
# └──────────────────────┴───────────────────────┴──────────────────────────┘
#
# IMPORTANT: Changing the encoder requires re-ingesting all documents, because
# embeddings are encoder-specific. Use a different CHUNKS_TABLE_VERSION (e.g. v4)
# to keep previous tables intact.
#
# Model files must exist at backend/models/<EMBEDDING_MODEL_DIR>/
#   - MrBERT: pre-existing in the repo
#   - Qwen3:  download with `cd backend && make download-qwen3`

EMBEDDING_MODEL_DIR=Qwen3-Embedding-0.6B
POOLING_STRATEGY=last_token
MAX_LENGTH=32768
EMBEDDING_DIM=1024

# Instruction prefix prepended to queries before encoding (Qwen3 is
# instruction-aware). Leave empty for MrBERT or other models that don't
# support instruction prefixes.

EMBEDDING_QUERY_INSTRUCTION=Recupera elementos patrimoniales relevantes para la siguiente consulta.


# =============================================================================
# LLM SERVICE
# =============================================================================
# Two LLM backends are supported:
#
#   vllm   — self-hosted via vLLM (requires NVIDIA GPU, started with profile "llm")
#   gemini — Google Gemini API (requires GEMINI_API_KEY, no GPU needed)
#
# LLM_PROVIDER selects which backend the API uses at runtime.

LLM_PROVIDER=gemini

# vLLM model (used both by the vllm-service container and the API to identify
# the model). Only relevant when LLM_PROVIDER=vllm.

LLM_MODEL_NAME=BSC-LT/salamandra-7b-instruct

# Generation parameters (apply to both providers)
#   LLM_MAX_TOKENS                — max tokens for RAG/chat responses
#   LLM_ROUTE_NARRATIVE_MAX_TOKENS — max tokens for route narrative generation
#   LLM_TEMPERATURE               — sampling temperature (0.0 = deterministic)

LLM_MAX_TOKENS=512
LLM_ROUTE_NARRATIVE_MAX_TOKENS=2048
LLM_TEMPERATURE=0.7

# API key to protect the vLLM service endpoint. vLLM validates the
# Authorization: Bearer <key> header natively via --api-key flag.
# Leave empty to disable (e.g. for local development without auth).

LLM_API_KEY=

# Gemini credentials (required when LLM_PROVIDER=gemini)

GEMINI_API_KEY=
GEMINI_MODEL_NAME=gemini-3.1-flash-lite-preview


# =============================================================================
# RAG PIPELINE
# =============================================================================
# These parameters control the Retrieval-Augmented Generation pipeline:
#
#   1. Query → embedding (via embedding service)
#   2. Hybrid search: vector (pgvector cosine) + full-text (tsvector)
#   3. Reciprocal Rank Fusion
#   4. Relevance filter (cosine distance > threshold → dropped)
#   5. Heuristic reranking (title match, coverage, position)
#   6. Top-K chunks → LLM context
#   7. LLM generation
#
# RAG_SIMILARITY_ONLY — if true, skip full-text search (vector search only).
#                       Useful when the text index is not yet built.

RAG_SIMILARITY_ONLY=true

# RAG_SIMILARITY_THRESHOLD — maximum cosine distance to keep a chunk.
#                            Lower = stricter (fewer but more relevant results).
#                            Range: 0.0 (exact match only) to 1.0 (keep everything).

RAG_SIMILARITY_THRESHOLD=0.45

# RAG_TOP_K — number of chunks sent to the LLM after reranking.

RAG_TOP_K=5

# RAG_RETRIEVAL_K — number of candidates retrieved from each search method
#                   (vector + full-text) before fusion. Higher = better recall
#                   but slower.

RAG_RETRIEVAL_K=20

# RAG_SCORE_THRESHOLD — minimum fused score to keep a chunk after fusion.
#                       Applied after Reciprocal Rank Fusion.

RAG_SCORE_THRESHOLD=0.35

# RAG_CHUNK_SIZE / RAG_CHUNK_OVERLAP — chunk splitting parameters (in tokens).
#                                       Only used during document ingestion.

RAG_CHUNK_SIZE=1024
RAG_CHUNK_OVERLAP=128

# CHUNKS_TABLE_VERSION — database table suffix for document chunks.
#                        Change when re-ingesting with a different encoder or
#                        chunking strategy to avoid overwriting previous data.
#                        Values: v1 (fixed window), v2 (paragraphs + header),
#                        v3 (+ type-specific metadata), v4 (natural language templates)

CHUNKS_TABLE_VERSION=v4


# =============================================================================
# RERANKER (co-located with embedding service)
# =============================================================================
# Neural cross-encoder reranker (Qwen3-Reranker-0.6B). Served by the embedding
# service at POST /rerank — no separate container needed.
#
# When enabled, replaces the heuristic reranker with a cross-encoder that
# scores query-document relevance using a transformer model.
# Recommended config: RAG_SIMILARITY_ONLY=true + RERANKER_ENABLED=true
#
# The reranker model is loaded automatically by the embedding service when
# model files exist at backend/models/Qwen3-Reranker-0.6B/
#   Download with: cd backend && make download-reranker
#
RERANKER_ENABLED=false
RERANKER_INSTRUCTION=Given a heritage search query, retrieve relevant heritage documents.
RERANKER_TOP_N=50
RERANKER_MAX_LENGTH=1024
RERANKER_BATCH_SIZE=1


# =============================================================================
# SEARCH
# =============================================================================
# The search context (faceted heritage asset search) uses separate thresholds
# from the RAG pipeline, because search requires higher precision over broader
# result sets.

# SEARCH_RETRIEVAL_K — candidates per search method (higher than RAG because
#                      search paginates over many results).

SEARCH_RETRIEVAL_K=200

# SEARCH_SCORE_THRESHOLD — stricter than RAG to reduce noise in search results.

SEARCH_SCORE_THRESHOLD=0.55


# =============================================================================
# API
# =============================================================================
# API_V1_PREFIX — URL prefix for all API endpoints (e.g. /api/v1/rag/query).

API_V1_PREFIX=/api/v1

# PROJECT_NAME — displayed in the OpenAPI docs title.

PROJECT_NAME=IAPH Heritage RAG

# DEBUG — enables debug logging and detailed error responses.
#         Set to false in production.

DEBUG=false

# CORS_ORIGINS — allowed origins for Cross-Origin Resource Sharing.
#   *                               → allow all origins (development)
#   https://example.com,https://admin.example.com → restrict to specific origins (production)

CORS_ORIGINS=*


# =============================================================================
# AUTH
# =============================================================================
# JWT-based authentication with DB-backed users.
# Users are managed via CLI: make manage-users ARGS="create-user --username x --password y"
# IMPORTANT: Change JWT_SECRET_KEY in production to a long random string.

JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin


# =============================================================================
# FRONTEND
# =============================================================================
# NEXT_PUBLIC_API_URL — the backend API URL as seen by the user's BROWSER.
#                       This is baked into the JavaScript bundle at build time
#                       (Next.js compiles NEXT_PUBLIC_* vars during `next build`).
#
#                       For local development: http://localhost:18080/api/v1
#                       For production:        https://your-domain.com/api/v1
#
#                       NOTE: This is NOT the internal Docker network URL.
#                       The browser cannot reach http://api:8080 — it needs
#                       the externally accessible URL.

NEXT_PUBLIC_API_URL=http://localhost:18080/api/v1


# =============================================================================
# PORTS
# =============================================================================
# Host ports exposed by each service. Change these if you have port conflicts.
# The container-internal ports are fixed (5432, 8001, 8000, 8080, 3000).
#
# When running the backend locally (not in Docker), use these ports in
# backend/config/.env to connect to the Docker services:
#   DATABASE_URL=postgresql+asyncpg://uja:uja@localhost:15432/uja_iaph
#   EMBEDDING_SERVICE_URL=http://localhost:18001

POSTGRES_PORT=15432
EMBEDDING_PORT=18001
LLM_PORT=18000
API_PORT=18080
FRONTEND_PORT=3000
