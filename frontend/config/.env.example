NEXT_PUBLIC_API_URL=http://localhost:18080/api/v1

# Default lexical weight in [0, 1] for the hybrid search slider.
# 0 = 100% semantic, 1 = 100% lexical, 0.5 = balanced mix.
# Injected at runtime in Docker; can be overridden by the user via the UI
# (stored per-page in localStorage as search:lexicalWeight / routes:lexicalWeight).
NEXT_PUBLIC_DEFAULT_LEXICAL_WEIGHT=0.5

# Server port (default 80 in Docker, 3000 in local dev)
# PORT=80
