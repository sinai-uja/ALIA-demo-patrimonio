.PHONY: dev install build start lint help

help:
	@echo "Usage: make <target>"
	@echo ""
	@echo "  dev      Start Next.js in development mode (hot-reload)"
	@echo "  install  Install npm dependencies"
	@echo "  build    Build for production"
	@echo "  start    Start production server"
	@echo "  lint     Run Next.js lint"

dev:
	npm run dev

install:
	npm install

build:
	npm run build

start:
	npm run start

lint:
	npm run lint
